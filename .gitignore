# Dependencies
node_modules/

# Build outputs
.next/
dist/
dist-electron/
release/
build/
*.tsbuildinfo

# In-place TypeScript emit (when tsc is invoked with emit on, .d.ts and
# .js appear next to their .ts / .tsx sources). Track emit outputs by
# filename pattern rather than path so genuine hand-written .d.ts
# files (e.g. src/global.d.ts, src/vite-env.d.ts) stay tracked.
src/**/*.d.ts
src/**/*.d.ts.map
src/**/*.js
src/**/*.js.map
!src/**/*.stories.tsx
!src/**/*.stories.ts

# Storybook
.storybook/
storybook-static/
src/stories/
# Co-located story files (Storybook v8+ convention) — not committed
*.stories.tsx
*.stories.ts
**/__stories__/

# Environment files
.env
.env.local
.env.*.local

# Runtime data
.duya/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Coverage
coverage/

# Testing
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
!src/lib/message-input-logic.spec.ts
!src/lib/chat-file-links.test.ts
!src/components/chat/RichTextInput.test.tsx
!src/hooks/useSubAgentProgress.test.ts
!src/hooks/__tests__/usePanel.test.ts
!src/components/chat/tools/rows/SubAgentToolRow.test.tsx
!src/components/layout/TaskDrawer.test.tsx
!src/components/chat/SlashCommandPopover.test.tsx
!packages/conductor/src/renderer/components/native/__tests__/native-element-capabilities.test.ts
!packages/conductor/src/renderer/components/native/editing/__tests__/useElementEditSession.test.tsx
!src/components/chat/SubAgentPanel.test.tsx
!src/components/chat/__tests__/FileEditToolRow.test.tsx
# Untrack unit-test source for these packages.
!packages/agent/tests/**/*.test.ts
!packages/agent/tests/**/*.test.tsx
!packages/agent/tests/**/*.spec.ts
!packages/agent/tests/**/*.spec.tsx
!packages/plugin-core/tests/**/*.test.ts
!packages/plugin-core/tests/**/*.test.tsx
!packages/plugin-core/tests/**/*.spec.ts
!packages/plugin-core/tests/**/*.spec.tsx
!electron/**/*.test.ts
# E2E specs (Playwright) live in e2e/ and MUST be tracked — they are
# integration tests, not scratch. Without this exception the broad
# *.spec.ts rule above silently strips them from version control.
!e2e/**/*.spec.ts
!e2e/**/*.spec.tsx
!e2e/**/*.test.ts
!e2e/**/*.test.tsx

# Project specific
ui-screenshot-*.png
console_log.txt
test_permissions.txt
test_paper.pdf
duyaUI.pen

# Agent tools
.claude/
.trae/
.qoder/
.playwright-mcp/
.playwright-cli/
.e2e-userdata/
tmp/

# Scratch debug / probe scripts (do not commit)
scripts/_probe-*.mjs
scripts/_probe-*.js
scripts/_scratch-*.mjs
scripts/_scratch-*.js
test-results/

# Docs (keep only product-specs and release-notes)
docs/*/
!docs/product-specs/
!docs/release-notes/
docs/*.md

# Tests
# Tests: only the root-level `tests/` scratch directory is ignored.
# `packages/agent/tests/` and `packages/plugin-core/tests/` are intentionally
# tracked — they hold the project's unit-test source.
/tests/

# Bundled output
packages/agent/bundle/
packages/gateway/bundle/
packages/cli/bundle/

# Bundled output


.cache/

# Temporary validation / probe scratch directories
.tmp-validation/
.tmp-test/
.tmp-electron-dev*.log
.tmp-electron-dev2*.log
.tmp-electron-dev3*.log
.tmp-electron-dev4*.log
.tmp-electron-dev5*.log
.tmp-electron-dev6*.log

# Local scratch / debug artifacts
_dbg-out.txt
.codex-artifacts/

# Local codegraph index
.codegraph/

# Ad-hoc scratch scripts left in repo root
/test-*.mjs
/*.cjs
/tc.out
/tc.out2
/diag.js
/fix-*.js

# Showcase / launch screenshot artifacts (regenerated by `npm run showcase`)
assets/showcase/

# Playwright scratch screenshots and ad-hoc agent/build output
output/

# Brainstorm visual companion scratch
.superpowers/
