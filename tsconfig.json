{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "@duya/agent": ["./packages/agent/dist"],
      "@duya/agent/*": ["./packages/agent/dist/*"],
      "@duya/conductor/renderer": ["./packages/conductor/src/renderer/index"],
      "@duya/conductor/renderer/*": ["./packages/conductor/src/renderer/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "packages/conductor/src/renderer/**/*.ts",
    "packages/conductor/src/renderer/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "electron/**",
    "src/**/*.stories.tsx",
    "src/**/*.stories.ts",
    "src/**/__stories__/**"
  ]
}
