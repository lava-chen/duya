{
  "name": "duya",
  "version": "0.4.0-beta.1",
  "description": "AI Agent Desktop Client (Beta)",
  "author": "lava-chen",
  "private": true,
  "main": "dist-electron/main.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build",
    "build:agent": "npm run build:cli && npm run -w @duya/agent build && npm run build:conductor",
    "build:cli": "npm run -w @duya/cli build",
    "build:conductor": "npm run -w @duya/conductor build",
    "build:gateway": "npm run -w @duya/gateway build",
    "bundle:agent": "node scripts/build-agent-bundle.mjs",
    "bundle:gateway": "node scripts/build-gateway-bundle.mjs",
    "build:docparser": "node scripts/build-document-parser-sidecar.mjs",
    "build:cli-bundle": "node scripts/build-cli-bundle.mjs",
    "rebuild:agent": "npm run build:agent && npm run bundle:agent",
    "preview": "vite preview",
    "electron:dev": "npm run bundle:agent && node scripts/build-electron.mjs && concurrently -k \"vite --port 3000 --strictPort\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build:agent && npm run bundle:agent && npm run build:cli-bundle && npm run build:gateway && npm run bundle:gateway && vite build && node scripts/build-electron.mjs",
    "electron:pack": "npm run electron:build && electron-builder --config electron-builder.yml",
    "electron:verify:packaged": "node scripts/verify-packaged-parity.mjs",
    "diagnose:env": "node scripts/diagnose-env.mjs",
    "diagnose:env-packed": "node scripts/diagnose-env.mjs --packaged",
    "diagnose:env-json": "node scripts/diagnose-env.mjs --json",
    "electron:preview": "npm run build:agent && npm run bundle:agent && vite build && node scripts/build-electron.mjs && cross-env DUYA_PREVIEW_MODE=true electron .",
    "electron:pack:mac": "npm run electron:build && electron-builder --mac --config electron-builder.yml",
    "electron:pack:win": "npm run electron:build && electron-builder --win --config electron-builder.yml",
    "electron:pack:linux": "npm run electron:build && electron-builder --linux --config electron-builder.yml",
    "typecheck": "npm run typecheck:web",
    "typecheck:web": "npm run build:agent && tsc --noEmit",
    "typecheck:agent": "npm run build:cli && npm run -w @duya/agent typecheck",
    "typecheck:cli": "npm run -w @duya/cli typecheck",
    "typecheck:conductor": "npm run -w @duya/conductor typecheck",
    "typecheck:all": "npm run typecheck:web && npm run typecheck:agent && npm run typecheck:cli && npm run typecheck:conductor",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bridge": "vitest run src/lib/bridge",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:smoke": "npx playwright test --config=e2e/playwright.config.ts --project=smoke",
    "test:e2e:ipc": "npx playwright test --config=e2e/playwright.config.ts --project=ipc",
    "build:electron": "node scripts/build-electron.mjs",
    "pack:extension": "node scripts/pack-extension.mjs",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/write-file-atomic": "^4.0.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "esbuild": "^0.27.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.2",
    "typescript": "^5.3.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "@lobehub/icons": "^5.4.0",
    "@lobehub/ui": "^5.7.0",
    "@phosphor-icons/react": "^2.1.10",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@swc/helpers": "^0.5.21",
    "@tabler/icons-react": "^3.43.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/diff": "^7.0.2",
    "@types/react-grid-layout": "^1.3.6",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "antd": "^6.3.5",
    "better-sqlite3": "^12.8.0",
    "certifi": "^14.5.15",
    "clsx": "^2.1.1",
    "croner": "^9.1.0",
    "diff": "^9.0.0",
    "docx": "^9.6.1",
    "electron-updater": "^6.8.3",
    "es-toolkit": "^1.45.1",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "https-proxy-agent": "^9.0.0",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-grid-layout": "^2.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "undici": "^6.25.0",
    "use-stick-to-bottom": "^1.1.3",
    "write-file-atomic": "^7.0.1",
    "zustand": "^5.0.12"
  }
}
