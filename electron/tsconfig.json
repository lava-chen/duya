{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "../dist-electron",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "typeRoots": ["./types", "./node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "./agents/**/*.ts",
    "./cli/**/*.ts",
    "./config/**/*.ts",
    "./db/**/*.ts",
    "./gateway/**/*.ts",
    "./import/**/*.ts",
    "./ipc/**/*.ts",
    "./logging/**/*.ts",
    "./messaging/**/*.ts",
    "./services/**/*.ts",
    "./wiki-agent/**/*.ts",
    "./automation/**/*.ts",
    "./main.ts",
    "./preload.ts"
  ],
  "exclude": ["node_modules", "*.test.ts"]
}
