{
  "name": "@duya/conductor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DUYA conductor — canvas orchestrator agent subsystem",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./ipc": {
      "types": "./dist/ipc.d.ts",
      "default": "./dist/ipc.js"
    },
    "./elements/widget-sanitizer": {
      "types": "./dist/elements/widget-sanitizer.d.ts",
      "default": "./dist/elements/widget-sanitizer.js"
    },
    "./elements/widget-css-bridge": {
      "types": "./dist/elements/widget-css-bridge.d.ts",
      "default": "./dist/elements/widget-css-bridge.js"
    }
  },
  "scripts": {
    "build": "tsc --incremental",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@duya/agent": "0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@duya/agent": "0.1.0",
    "@types/node": "^20.0.0",
    "@types/rbush": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "rbush": "^4.0.1"
  }
}
